<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{titulo}}KanbanPro</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header class="navbar">
        <div class="logo">KanbanPro</div>
        <nav class="nav-links">
            <a href="/" class="nav-item">Dashboard</a>
            
            {{#if usuario}}
                <span class="user-welcome">Hola, {{usuario.nombre}}</span>
                <a href="/logout" class="nav-item btn-logout">Cerrar Sesión</a>
            {{else}}
                <a href="/login" class="nav-item">Ingresar</a>
                <a href="/register" class="nav-item">Registro</a>
            {{/if}}
        </nav>
    </header>
    
    <main>
        {{{body}}}
    </main>

    <script src="/script.js"></script>
</body>
</html>